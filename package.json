{
  "name": "ai-delivery-workbench",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12 <23"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "registry:generate": "tsx scripts/generate-registry.ts",
    "registry:check": "tsx scripts/generate-registry.ts --check",
    "mcp:evidence:generate": "tsx scripts/generate-mcp-evidence.ts",
    "mcp:evidence:check": "tsx scripts/generate-mcp-evidence.ts --check",
    "trace:generate": "tsx scripts/generate-recorded-trace.ts",
    "trace:check": "tsx scripts/generate-recorded-trace.ts --check",
    "model-gateway:generate": "tsx scripts/generate-model-gateway-status.ts",
    "model-gateway:check": "tsx scripts/generate-model-gateway-status.ts --check",
    "model-gateway:evidence:validate": "tsx tools/model-gateway/cli.ts validate",
    "security:check": "tsx scripts/check-secret-leaks.ts",
    "model-gateway:up": "docker compose -f ops/model-gateway/compose.yaml up -d --wait",
    "model-gateway:down": "docker compose -f ops/model-gateway/compose.yaml down",
    "demo:model-gateway": "tsx tools/model-gateway/cli.ts run",
    "demo:model-gateway:live": "tsx tools/model-gateway/cli.ts run --profile live",
    "demo:model-gateway:cleanup": "tsx tools/model-gateway/cli.ts cleanup --profile live",
    "demo:sandbox": "tsx tools/local-sandbox/cli.ts run",
    "demo:sandbox:e2b": "tsx tools/local-sandbox/cli.ts run --provider e2b",
    "demo:sandbox:failure": "tsx tools/local-sandbox/cli.ts run --failed-validation",
    "sandbox:evidence:validate": "tsx tools/local-sandbox/cli.ts validate",
    "demo:approval:start": "tsx tools/demo-sandbox/cli.ts start",
    "demo:approve": "tsx tools/demo-sandbox/cli.ts approve",
    "demo:reject": "tsx tools/demo-sandbox/cli.ts reject",
    "demo:resume": "tsx tools/demo-sandbox/cli.ts resume",
    "test": "vitest run",
    "test:e2b:live": "vitest run tests/e2b-sandbox.live.test.ts",
    "test:model-gateway:live": "vitest run tests/model-gateway.live.test.ts",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test tests/e2e/accessibility.spec.ts",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run registry:check && npm run mcp:evidence:check && npm run sandbox:evidence:validate && npm run trace:check && npm run model-gateway:check && npm run model-gateway:evidence:validate && npm run test && npm run build && npm run security:check && npm run test:e2e"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/resources": "2.9.0",
    "@opentelemetry/sdk-trace-base": "2.9.0",
    "@opentelemetry/semantic-conventions": "1.43.0",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "e2b": "2.34.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@eslint/js": "10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "22.18.13",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
