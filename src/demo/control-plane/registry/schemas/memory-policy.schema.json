{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://portfolio.invalid/schemas/registry/memory-policy.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "id",
    "name",
    "version",
    "description",
    "status",
    "allowedRecordTypes",
    "allowedSourceTypes",
    "allowedSensitivities",
    "freshness",
    "maximumContextBytes",
    "maximumEstimatedTokens",
    "priorRunEpisodicMemoryPermitted",
    "retrievalMode",
    "selectionRuleVersion",
    "sourceCommit",
    "contentHash",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "kind": { "const": "MemoryPolicy" },
    "id": { "$ref": "common.schema.json#/$defs/identifier" },
    "name": { "type": "string", "minLength": 1 },
    "version": { "$ref": "common.schema.json#/$defs/semanticVersion" },
    "description": { "type": "string", "minLength": 1 },
    "status": { "$ref": "common.schema.json#/$defs/status" },
    "allowedRecordTypes": {
      "type": "array",
      "items": {
        "enum": [
          "ARCHITECTURE_DECISION",
          "ENGINEERING_CONVENTION",
          "DOMAIN_RULE",
          "ISSUE_EVIDENCE",
          "PRIOR_FAILURE",
          "PRIOR_FIX",
          "USER_PREFERENCE",
          "CUSTOM"
        ]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "allowedSourceTypes": {
      "type": "array",
      "items": {
        "enum": [
          "REPOSITORY",
          "ISSUE_FIXTURE",
          "DOCUMENTATION",
          "EVIDENCE",
          "USER_CONFIGURATION",
          "PRIOR_RUN",
          "CUSTOM"
        ]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "allowedSensitivities": {
      "type": "array",
      "items": { "enum": ["PUBLIC", "SYNTHETIC", "RESTRICTED_SYNTHETIC", "SECRET"] },
      "minItems": 1,
      "uniqueItems": true
    },
    "freshness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maximumAgeSeconds", "staleBehavior"],
      "properties": {
        "maximumAgeSeconds": { "type": "integer", "minimum": 0 },
        "staleBehavior": { "const": "EXCLUDE" }
      }
    },
    "maximumContextBytes": { "type": "integer", "minimum": 1024 },
    "maximumEstimatedTokens": { "type": "integer", "minimum": 128 },
    "priorRunEpisodicMemoryPermitted": { "type": "boolean" },
    "retrievalMode": { "const": "DETERMINISTIC_RULES" },
    "selectionRuleVersion": { "type": "string", "minLength": 1 },
    "sourceCommit": { "$ref": "common.schema.json#/$defs/sourceCommit" },
    "contentHash": { "$ref": "common.schema.json#/$defs/contentHash" },
    "createdAt": { "$ref": "common.schema.json#/$defs/timestamp" },
    "updatedAt": { "$ref": "common.schema.json#/$defs/timestamp" },
    "approval": { "$ref": "common.schema.json#/$defs/approval" }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "APPROVED" } }, "required": ["status"] },
      "then": { "properties": { "approval": true }, "required": ["approval"] }
    }
  ]
}
