{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://portfolio.invalid/schemas/registry/model-policy.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "id",
    "name",
    "version",
    "description",
    "status",
    "providerCategory",
    "preferredModelId",
    "allowedProviderIds",
    "allowedModelIds",
    "fallbackOrder",
    "reasoningProfile",
    "temperature",
    "maximumInputTokens",
    "maximumOutputTokens",
    "maximumCostUsd",
    "maximumLatencyMs",
    "allowedStages",
    "allowedTasks",
    "independentReview",
    "executionMode",
    "sourceCommit",
    "contentHash",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "kind": { "const": "ModelPolicy" },
    "id": { "$ref": "common.schema.json#/$defs/identifier" },
    "name": { "type": "string", "minLength": 1 },
    "version": { "$ref": "common.schema.json#/$defs/semanticVersion" },
    "description": { "type": "string", "minLength": 1 },
    "status": { "$ref": "common.schema.json#/$defs/status" },
    "providerCategory": {
      "enum": [
        "PROVIDER_NEUTRAL_SIMULATED",
        "LOCAL_DETERMINISTIC",
        "OPENAI_COMPATIBLE_LOCAL_GATEWAY"
      ]
    },
    "preferredModelId": { "type": "string", "minLength": 1 },
    "allowedProviderIds": { "$ref": "common.schema.json#/$defs/nonEmptyStrings" },
    "allowedModelIds": { "$ref": "common.schema.json#/$defs/nonEmptyStrings" },
    "fallbackOrder": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "reasoningProfile": { "enum": ["LOW", "BALANCED", "HIGH"] },
    "temperature": {
      "oneOf": [{ "type": "number", "minimum": 0, "maximum": 2 }, { "type": "null" }]
    },
    "maximumInputTokens": { "type": "integer", "minimum": 1 },
    "maximumOutputTokens": { "type": "integer", "minimum": 1 },
    "maximumCostUsd": { "type": "number", "minimum": 0 },
    "maximumLatencyMs": { "type": "integer", "minimum": 1 },
    "allowedStages": {
      "type": "array",
      "items": {
        "enum": ["intake", "spec", "plan", "targets", "implement", "verify", "review"]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "allowedTasks": {
      "type": "array",
      "items": { "enum": ["ARTIFACT_DRAFT", "CODE_CHANGE", "INDEPENDENT_REVIEW"] },
      "minItems": 1,
      "uniqueItems": true
    },
    "independentReview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "modelId"],
      "properties": {
        "required": { "type": "boolean" },
        "modelId": { "oneOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }] }
      }
    },
    "executionMode": { "enum": ["OFFLINE_ONLY", "EXPLICIT_LOCAL_PROFILE"] },
    "sourceCommit": { "$ref": "common.schema.json#/$defs/sourceCommit" },
    "contentHash": { "$ref": "common.schema.json#/$defs/contentHash" },
    "createdAt": { "$ref": "common.schema.json#/$defs/timestamp" },
    "updatedAt": { "$ref": "common.schema.json#/$defs/timestamp" },
    "approval": { "$ref": "common.schema.json#/$defs/approval" }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "APPROVED" } }, "required": ["status"] },
      "then": { "properties": { "approval": true }, "required": ["approval"] }
    }
  ]
}
