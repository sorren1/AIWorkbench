{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://portfolio.invalid/schemas/registry/agent-card.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "id",
    "name",
    "version",
    "description",
    "owner",
    "status",
    "stageId",
    "capabilities",
    "skills",
    "inputSchema",
    "outputSchema",
    "allowedToolIds",
    "allowedWritePaths",
    "modelPolicyId",
    "memoryPolicyId",
    "approvalPolicyIds",
    "maxDurationMs",
    "maxToolCalls",
    "maxRepairAttempts",
    "sourceCommit",
    "contentHash",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "kind": { "const": "AgentCard" },
    "id": { "$ref": "common.schema.json#/$defs/identifier" },
    "name": { "type": "string", "minLength": 1 },
    "version": { "$ref": "common.schema.json#/$defs/semanticVersion" },
    "description": { "type": "string", "minLength": 1 },
    "owner": { "type": "string", "minLength": 1 },
    "status": { "$ref": "common.schema.json#/$defs/status" },
    "stageId": { "$ref": "common.schema.json#/$defs/stage" },
    "capabilities": { "$ref": "common.schema.json#/$defs/nonEmptyStrings" },
    "skills": { "$ref": "common.schema.json#/$defs/nonEmptyStrings" },
    "inputSchema": { "$ref": "common.schema.json#/$defs/schemaReference" },
    "outputSchema": { "$ref": "common.schema.json#/$defs/schemaReference" },
    "allowedToolIds": { "$ref": "common.schema.json#/$defs/nonEmptyStrings" },
    "allowedWritePaths": { "$ref": "common.schema.json#/$defs/nonEmptyStrings" },
    "modelPolicyId": { "$ref": "common.schema.json#/$defs/identifier" },
    "memoryPolicyId": { "$ref": "common.schema.json#/$defs/identifier" },
    "approvalPolicyIds": { "$ref": "common.schema.json#/$defs/nonEmptyStrings" },
    "maxDurationMs": { "type": "integer", "minimum": 100, "maximum": 900000 },
    "maxToolCalls": { "type": "integer", "minimum": 0, "maximum": 100 },
    "maxRepairAttempts": { "type": "integer", "minimum": 0, "maximum": 10 },
    "tokenBudget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxInputTokens", "maxOutputTokens", "basis"],
      "properties": {
        "maxInputTokens": { "type": "integer", "minimum": 1 },
        "maxOutputTokens": { "type": "integer", "minimum": 1 },
        "basis": { "const": "ESTIMATED" }
      }
    },
    "costBudget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxEstimatedUsd", "basis"],
      "properties": {
        "maxEstimatedUsd": { "type": "number", "minimum": 0 },
        "basis": { "const": "ESTIMATED" }
      }
    },
    "sourceCommit": { "$ref": "common.schema.json#/$defs/sourceCommit" },
    "contentHash": { "$ref": "common.schema.json#/$defs/contentHash" },
    "createdAt": { "$ref": "common.schema.json#/$defs/timestamp" },
    "updatedAt": { "$ref": "common.schema.json#/$defs/timestamp" },
    "approval": { "$ref": "common.schema.json#/$defs/approval" }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "APPROVED" } }, "required": ["status"] },
      "then": { "properties": { "approval": true }, "required": ["approval"] }
    }
  ]
}
