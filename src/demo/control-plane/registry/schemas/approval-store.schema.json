{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://portfolio.invalid/schemas/registry/approval-store.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "requests", "events"],
  "properties": {
    "version": { "const": 1 },
    "requests": {
      "type": "object",
      "additionalProperties": { "$ref": "approval-request.schema.json" }
    },
    "events": {
      "type": "array",
      "items": { "$ref": "approval-event.schema.json" }
    }
  }
}
