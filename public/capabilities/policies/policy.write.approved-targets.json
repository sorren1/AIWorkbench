{
  "kind": "ApprovalPolicy",
  "enabled": true,
  "provenance": {
    "sourceCommit": "6ff396739f4f8afbf7af966e202a45a00eb0eeaa",
    "independentlyAuthored": true,
    "createdAt": "2026-07-17T12:00:00.000Z"
  },
  "id": "policy.write.approved-targets",
  "name": "Controlled writes inside approved targets",
  "version": "1.0.0",
  "description": "Requires a distinct code reviewer for a patch bounded by all write allow-lists.",
  "matcher": {
    "toolIds": ["tool.repository.patch.controlled"],
    "stages": ["implement"],
    "riskLevels": ["HIGH"],
    "pathPatterns": ["src/**"],
    "pathBoundary": "INSIDE_APPROVED_TARGETS"
  },
  "mode": "REQUIRE_APPROVAL",
  "requiredApproverScopes": ["diff:review"],
  "requiredApproverPersonas": ["synthetic-code-reviewer"],
  "timeoutSeconds": 1800,
  "decisionCacheTtlSeconds": 300,
  "forbidSelfApproval": true,
  "reasonRequired": true,
  "contentHash": "34c35b0ede6ee6b446f56a8e2f577f437b8b8dfcfa91cc99137b40f9053e9764"
}
